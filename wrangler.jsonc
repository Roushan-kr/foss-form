{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "foss-form",
	"compatibility_date": "2025-04-04",
	"compatibility_flags": [
        "nodejs_compat"
    ],
	"main": "./workers/app.ts",
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "foss-form",
			"database_id": "87ac6de4-341b-449a-8963-4f378ab6597a",
		}
	]
}